#!/bin/sh

# Ensure Homebrew tools are on PATH (Linux + macOS)
PATH="/opt/homebrew/bin:/home/linuxbrew/.linuxbrew/bin:$PATH"

# Colors
RED=$(printf '\033[0;31m')
GREEN=$(printf '\033[0;32m')
BLUE=$(printf '\033[1;34m')
NC=$(printf '\033[0m') # No Color

start_total=$(date +%s)

print_header() {
  echo "${BLUE}[pre-commit check $1] $2"
}

check_step() {
  step=$1
  shift

  print_header "$step" "Running '$*'...${NC}"
  step_start=$(date +%s)

  "$@"
  status=$?

  step_duration=$(( $(date +%s) - step_start ))

  if [ $status -ne 0 ]; then
    echo "${RED}✘ '$*' failed after ${step_duration}s${NC}"
    exit 1
  else
    echo "${GREEN}✔ '$*' passed in ${step_duration}s${NC}"
  fi
  echo ""
}

check_step "1/2" ansible-playbook --syntax-check local.yml
check_step "2/2" ansible-lint

total_duration=$(( $(date +%s) - start_total ))
echo "${GREEN}All checks passed in ${total_duration}s! 🚀${NC}"
exit 0
